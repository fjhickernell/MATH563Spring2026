/*-- scss:rules --*/

.reveal .footer,
.reveal .fh-footer {
  display: none !important;
}

.reveal .slides section#research-title-slide .pkg {
  background: rgba(255,255,255,0.18);
  padding: 0.06em 0.35em;
  border-radius: 4px;
  font-weight: 600;
}

.reveal .slides section#research-title-slide,
.reveal .slides section#research-title-slide h1,
.reveal .slides section#research-title-slide p,
.reveal .slides section#research-title-slide div,
.reveal .slides section#research-title-slide span,
.reveal .slides section#research-title-slide a {
  color: white !important;
  text-shadow: 0 2px 10px rgba(0,0,0,0.45);
}

.reveal .slides section#research-title-slide > h1 {
  position: relative;
  z-index: 2;
  left: 50%;
  transform: translateX(-50%);
  width: calc(90vw / var(--reveal-scale,1)) !important;
  max-width: 1400px !important;
  text-align: center !important;

  text-shadow:
    0 2px 10px rgba(0,0,0,0.6),
    0 4px 22px rgba(0,0,0,0.55);

  background: none !important;
  border: none !important;
  box-shadow: none !important;

  margin-top: 0 !important;
  margin-bottom: 0.40em !important;
  padding: 0.10em 0 0.15em 0 !important;

  font-size: 1.80em;
  line-height: 1.10;
}

.reveal .slides section#research-title-slide > .title-stack {
  position: relative;
  z-index: 2;
  left: 50%;
  transform: translateX(-50%);
  width: calc(90vw / var(--reveal-scale,1)) !important;
  max-width: 1400px !important;
  margin-top: 3em !important;
  text-align: center !important;
}

.reveal .slides section#research-title-slide .title-stack p,
.reveal .slides section#research-title-slide .title-stack div {
  width: 100% !important;
  max-width: none !important;
  text-align: center !important;
}

.reveal .slides section#research-title-slide .author {
  font-size: 0.88em;
  margin-top: 0.30em;
}

.reveal .slides section#research-title-slide .speaker {
  font-weight: 700;
}

.reveal .slides section#research-title-slide .affiliation,
.reveal .slides section#research-title-slide .email {
  font-weight: 400;
}

.reveal .slides section#research-title-slide .email {
  overflow-wrap: anywhere;
  word-break: break-word;
}

.reveal .slides section#research-title-slide .collaborators,
.reveal .slides section#research-title-slide .funding,
.reveal .slides section#research-title-slide .slides-link {
  font-size: 0.76em;
  margin-top: 0.24em;
}

